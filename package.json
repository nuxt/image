{
  "name": "@nuxt/image",
  "version": "2.0.0",
  "description": "Nuxt Image Module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/image.git"
  },
  "homepage": "https://image.nuxt.com",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/module.js",
    "./runtime": "./dist/runtime/index.js",
    "./runtime/providers/*": "./dist/runtime/providers/*.js"
  },
  "main": "./dist/module.js",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.ts"
      ],
      "./runtime": [
        "./dist/runtime/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:generate": "nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare docs",
    "docs:build": "pnpm run --filter docs build",
    "docs:dev": "pnpm run --filter docs dev",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "prepack": "pnpm build",
    "release": "pnpm test && pnpm build && changelogen --release --push && npm publish",
    "test": "nuxt prepare playground && pnpm vitest run --coverage",
    "test:types": "vue-tsc --noEmit",
    "test:built:types": "nuxt typecheck playground && nuxt typecheck example"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@nuxt/kit": "^4.4.4",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "h3": "^1.15.11",
    "image-meta": "^0.2.2",
    "knitwork": "^1.3.0",
    "ohash": "^2.0.11",
    "pathe": "^2.0.3",
    "std-env": "^4.1.0",
    "ufo": "^1.6.3"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "1.15.2",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.4",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "@unhead/vue": "^2.1.13",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "changelogen": "^0.6.2",
    "eslint": "10.2.1",
    "happy-dom": "^20.9.0",
    "installed-check": "^10.0.1",
    "ipx": "^3.1.1",
    "jiti": "2.6.1",
    "knip": "^6.7.0",
    "nitropack": "^2.13.3",
    "nuxt": "^4.4.4",
    "ofetch": "^1.5.1",
    "pkg-pr-new": "^0.0.67",
    "playwright-core": "^1.59.1",
    "semver": "^7.7.4",
    "tinyexec": "^1.1.1",
    "tinyglobby": "^0.2.16",
    "typescript": "6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.5",
    "vue": "3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "optionalDependencies": {
    "ipx": "^3.1.1"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18.20.6"
  }
}
